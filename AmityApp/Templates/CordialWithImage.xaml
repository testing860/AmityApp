<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AmityApp.Templates.CordialWithImage"
             xmlns:controls="clr-namespace:AmityApp.Controls"
             xmlns:dtos="clr-namespace:AmityApp.Shared.Dtos;assembly=AmityApp.Shared"
             xmlns:models="clr-namespace:AmityApp.Models"
             xmlns:converters="clr-namespace:AmityApp.Converters"
             xmlns:vm="clr-namespace:AmityApp.ViewModels"
             x:DataType="models:CordialModel">

    <Border Padding="0, 8" BackgroundColor="{StaticResource White}" StrokeThickness="0">
        <Grid RowDefinitions="Auto, 250, Auto, Auto" RowSpacing="6">
            <Grid ColumnDefinitions="40, Auto, *" ColumnSpacing="6" Padding="8, 0">
                <!-- Avatar -->
                <Border Grid.Column="0" HeightRequest="40" StrokeShape="RoundRectangle 20"
            BackgroundColor="{StaticResource Surface}" WidthRequest="40">
                    <Image Source="{Binding FullUserPhotoUrl}" Aspect="AspectFill"
               HeightRequest="40" WidthRequest="40"
               VerticalOptions="Center" HorizontalOptions="Center">
                        <Image.Clip>
                            <EllipseGeometry Center="20,20" RadiusX="20" RadiusY="20"/>
                        </Image.Clip>
                    </Image>
                </Border>

                <!-- Username, Dot, Timestamp -->
                <Grid Grid.Column="1" ColumnDefinitions="Auto, Auto, Auto"
          ColumnSpacing="5" VerticalOptions="Center">
                    <Label Grid.Column="0" FontAttributes="Bold" Text="{Binding UserName}" />
                    <Label Grid.Column="1" FontAttributes="Bold" Text="·" FontSize="14" VerticalOptions="Center"/>
                    <Label Grid.Column="2" FontSize="12"
               Text="{Binding PostedOnDisplay, Converter={StaticResource RelativeTimeConverter}}"
               VerticalOptions="Center"/>
                </Grid>

                <!-- Vibe (right‑aligned) -->
                <!-- Vibe badge (solid pill, white icon via WhiteIcon control) -->
                <Border Grid.Column="2" Padding="8,4"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="0"
                        BackgroundColor="{Binding VibeColor}"
                        HorizontalOptions="End"
                        VerticalOptions="Center"
                        IsVisible="{Binding HasVibe}">
                    <HorizontalStackLayout Spacing="4">
                        <controls:WhiteIcon Source="{Binding VibeIcon}"
                            HeightRequest="24" WidthRequest="24"
                            VerticalOptions="Center" />
                        <Label Text="{Binding VibeDisplay}"
               FontSize="14"
                               FontAttributes="Bold"
               VerticalOptions="Center"
               TextColor="White" />
                    </HorizontalStackLayout>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    BackgroundColor="{StaticResource Surface}"
                    HeightRequest="250"
                    StrokeThickness="0">
                <Image Aspect="Center"
                       HeightRequest="250"
                       Source="{Binding FullPhotoUrl}" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding Source={x:RelativeSource AncestorType={x:Type vm:BaseCordialViewModel}}, Path=GoToDetailsPageCommand}" CommandParameter="{Binding .}"/>
                </Border.GestureRecognizers>
            </Border>
            <Label
                Grid.Row="2"
                FontSize="15"
                Text="{Binding Content}"
                TextColor="{StaticResource SecondaryDarkText}" 
                Padding="8, 0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding Source={x:RelativeSource AncestorType={x:Type vm:BaseCordialViewModel}}, Path=GoToDetailsPageCommand}" CommandParameter="{Binding .}"/>
                </Label.GestureRecognizers>
                </Label>

            <VerticalStackLayout Grid.Row="3" Spacing="10">
                <BoxView Style="{StaticResource fadedLine}" />
                <FlexLayout JustifyContent="SpaceAround">
                    <HorizontalStackLayout Spacing="2">
                        <controls:PrimaryColorImage 
                            HeightRequest="20"
                            Source="{Binding IsLitIcon}"
                            VerticalOptions="Center"
                            WidthRequest="20" />
                        <Label
                            FontSize="12"
                            Text="Light"
                            VerticalOptions="Center" />
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={x:RelativeSource AncestorType={x:Type vm:BaseCordialViewModel}}, Path=ToggleCandleCommand}" CommandParameter="{Binding .}"/>
                        </HorizontalStackLayout.GestureRecognizers>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="2">
                        <controls:PrimaryColorImage 
                            HeightRequest="20"
                            Source="bubble.png"
                            VerticalOptions="Center"
                            WidthRequest="20" />
                        <Label
                            FontSize="12"
                            Text="Comment"
                            VerticalOptions="Center" />
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={x:RelativeSource AncestorType={x:Type vm:BaseCordialViewModel}}, Path=GoToDetailsPageCommand}" CommandParameter="{Binding .}"/>
                        </HorizontalStackLayout.GestureRecognizers>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="2">
                        <controls:PrimaryColorImage 
                            HeightRequest="20"
                            Source="{Binding IsCrownedIcon}"
                            VerticalOptions="Center"
                            WidthRequest="20" />
                        <Label
                            FontSize="12"
                            Text="Save"
                            VerticalOptions="Center" />
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={x:RelativeSource AncestorType={x:Type vm:BaseCordialViewModel}}, Path=ToggleCrownCommand}" CommandParameter="{Binding .}"/>
                        </HorizontalStackLayout.GestureRecognizers>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="2">
                        <controls:PrimaryColorImage 
                            HeightRequest="20"
                            Source="share.svg"
                            VerticalOptions="Center"
                            WidthRequest="20" />
                        <Label
                            FontSize="12"
                            Text="Share"
                            VerticalOptions="Center" />
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={x:RelativeSource AncestorType={x:Type vm:BaseCordialViewModel}}, Path=ShareCordialCommand}" CommandParameter="{Binding .}"/>
                        </HorizontalStackLayout.GestureRecognizers>
                    </HorizontalStackLayout>
                </FlexLayout>
            </VerticalStackLayout>
        </Grid>
    </Border>
</ContentView>