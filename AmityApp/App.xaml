<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AmityApp"
             xmlns:controls="clr-namespace:AmityApp.Controls"
             xmlns:templates="clr-namespace:AmityApp.Templates"
             xmlns:converters="clr-namespace:AmityApp.Converters"
             x:Class="AmityApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />

                <ResourceDictionary>

                    <!-- // Changing White -->
                    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource Background}" />
                    </Style>

                    <Style x:Key="formLabel" TargetType="Label" >
                        <Setter Property="FontAttributes" Value="Bold" />
                    </Style>

                    <Style x:Key="rounded" TargetType="Button" >
                        <Setter Property="CornerRadius" Value="22" />
                    </Style>

                    <Style x:Key="fadedLine" TargetType="BoxView" >
                        <Setter Property="HeightRequest" Value="1" />
                        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                        <Setter Property="Opacity" Value="0.2" />
                    </Style>

                    <Style TargetType="controls:NoBorderEntry" >
                        <Setter Property="BackgroundColor" Value="{StaticResource Surface}"/>
                    </Style>

                    <DataTemplate x:Key="cordialWithImageTemplate">
                        <templates:CordialWithImage />
                    </DataTemplate>
                    <DataTemplate x:Key="cordialWithNoImageTemplate">
                        <templates:CordialWithNoImage />
                    </DataTemplate>
                    <DataTemplate x:Key="cordialWithImageOnlyTemplate">
                        <templates:CordialWithOnlyImage />
                    </DataTemplate>

                    <templates:CordialTemplateSelector x:Key="cordialDataTemplateSelector"
                                                       WithImage="{StaticResource cordialWithImageTemplate}"
                                                       WithNoImage="{StaticResource cordialWithNoImageTemplate}"
                                                       ImageOnly="{StaticResource cordialWithImageOnlyTemplate}"/>

                    <converters:RelativeTimeConverter x:Key="RelativeTimeConverter" />

                </ResourceDictionary>


            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>