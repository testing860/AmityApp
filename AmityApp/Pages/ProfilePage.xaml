<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AmityApp.Pages.ProfilePage"
             xmlns:controls="clr-namespace:AmityApp.Controls"
             Title="My Profile"
             BackgroundColor="{StaticResource Background}">

    <ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="logout.png"
                     Clicked="OnLogoutClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, *">
        <VerticalStackLayout Grid.Row="0" Padding="15, 10, 15, 10">
            <Grid>
                <Border
                    BackgroundColor="{StaticResource Surface}"
                    HeightRequest="100"
                    StrokeShape="RoundRectangle 50"
                    WidthRequest="100">
                    <Image
                        HorizontalOptions="Center"
                        Source="user.png"
                        VerticalOptions="Center"
                        WidthRequest="80"
                        HeightRequest="80"/>
                </Border>
                <Border
                    Margin="0,0,-80,0"
                    BackgroundColor="{StaticResource Primary}"
                    HeightRequest="28"
                    StrokeShape="RoundRectangle 14"
                    VerticalOptions="End"
                    WidthRequest="28"
                    StrokeThickness="0">
                    <controls:WhiteIcon
                        HeightRequest="16"
                        HorizontalOptions="Center"
                        Source="pencil.png"
                        VerticalOptions="Center"
                        WidthRequest="16" />
                    <Border.Shadow>
                        <Shadow />
                    </Border.Shadow>
                </Border>
            </Grid>
            <Label
                Margin="0,10,0,0"
                FontAttributes="Bold"
                FontSize="18"
                HorizontalOptions="Center"
                Text="Jim Placeholder" />
            <Label
                FontSize="16"
                HorizontalOptions="Center"
                Text="test@email.com" />
            <BoxView Style="{StaticResource fadedLine}"/>

            <Border
                Margin="0,5,0,0"
                HeightRequest="30"
                Stroke="{StaticResource Primary}"
                StrokeShape="RoundRectangle 15"
                StrokeThickness="0.5">
                <Grid ColumnDefinitions="*, *">
                    <Border
                        Grid.Column="0"
                        BackgroundColor="{StaticResource Primary}"
                        StrokeThickness="0">
                        <Label
                            HorizontalOptions="Center"
                            Text="My Posts"
                            TextColor="White"
                            VerticalOptions="Center" />
                    </Border>
                    <Border
                        Grid.Column="1"
                        BackgroundColor="White"
                        StrokeThickness="0">
                        <Label
                            HorizontalOptions="Center"
                            Text="Bookmarked"
                            TextColor="{StaticResource Primary}"
                            VerticalOptions="Center" />
                    </Border>
                </Grid>
            </Border>

        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="15">
                <Border Padding="0, 8" BackgroundColor="{StaticResource White}" StrokeThickness="0">
                    <Grid RowDefinitions="Auto, 250, Auto, Auto" RowSpacing="6">
                        <Grid ColumnDefinitions="40, Auto, *" ColumnSpacing="6" Padding="8, 0">
                            <Border Grid.Column="0"
                                HeightRequest="40"
                                StrokeShape="RoundRectangle 20"
                                BackgroundColor="{StaticResource Surface}"
                                WidthRequest="40">
                                <Image 
                                     Source="user.png"
                                     Aspect="AspectFit"
                                     HeightRequest="30"
                                     WidthRequest="30"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"/>
                            </Border>
                            <Grid
                                Grid.Column="1"
                                ColumnDefinitions="Auto, Auto, Auto"
                                ColumnSpacing="5"
                                VerticalOptions="Center">
                                <Label
                                    Grid.Column="0"
                                    FontAttributes="Bold"
                                    Text="Jim Placeholder" />
                                <Label
                                    Grid.Column="1"
                                    FontAttributes="Bold"
                                    Text="." 
                                    FontSize="14"
                                    Margin="0, -7, 0, 0"
                                    VerticalOptions="Center"/>
                                <Label
                                    Grid.Column="2"
                                    FontSize="12"
                                    Text="12 April 2026"
                                    VerticalOptions="Center"/>
                            </Grid>
                        </Grid>

                        <Border Grid.Row="1"
                            BackgroundColor="{StaticResource Surface}"
                            HeightRequest="250"
                            StrokeThickness="0">
                            <Image Aspect="Center"
                               HeightRequest="250"
                               Source="cat.png" />
                        </Border>
                        <Label
                            Grid.Row="2"
                            FontSize="15"
                            Text="Meow, meow."
                            TextColor="{StaticResource SecondaryDarkText}" 
                            Padding="8, 0"/>

                        <VerticalStackLayout Grid.Row="3" Spacing="10">
                            <BoxView Style="{StaticResource fadedLine}" />
                            <FlexLayout JustifyContent="SpaceAround">
                                <HorizontalStackLayout Spacing="2">
                                    <controls:PrimaryColorImage 
                                        HeightRequest="20"
                                        Source="candle.svg"
                                        VerticalOptions="Center"
                                        WidthRequest="20" />
                                    <Label
                                        FontSize="12"
                                        Text="Light"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="2">
                                    <controls:PrimaryColorImage 
                                        HeightRequest="20"
                                        Source="bubble.png"
                                        VerticalOptions="Center"
                                        WidthRequest="20" />
                                    <Label
                                        FontSize="12"
                                        Text="Comment"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="2">
                                    <controls:PrimaryColorImage 
                                        HeightRequest="20"
                                        Source="bookmark.png"
                                        VerticalOptions="Center"
                                        WidthRequest="20" />
                                    <Label
                                        FontSize="12"
                                        Text="Save"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="2">
                                    <controls:PrimaryColorImage 
                                        HeightRequest="20"
                                        Source="share.svg"
                                        VerticalOptions="Center"
                                        WidthRequest="20" />
                                    <Label
                                        FontSize="12"
                                        Text="Share"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </FlexLayout>
                        </VerticalStackLayout>

                    </Grid>

                </Border>
                <Border Padding="0, 8" BackgroundColor="{StaticResource White}" StrokeThickness="0">
                    <Grid RowDefinitions="Auto, 250, Auto" RowSpacing="6">
                        <Grid ColumnDefinitions="40, Auto, *" ColumnSpacing="6" Padding="8, 0">
                            <Border Grid.Column="0"
                                    HeightRequest="40"
                                    StrokeShape="RoundRectangle 20"
                                        BackgroundColor="{StaticResource Surface}"
                                    WidthRequest="40">
                                <Image 
                                    Source="user.png"
                                   Aspect="AspectFit"
                                   HeightRequest="30"
                                   WidthRequest="30"
                                   VerticalOptions="Center"
                                    HorizontalOptions="Center"/>
                            </Border>
                            <Grid
                                Grid.Column="1"
                                ColumnDefinitions="Auto, Auto, Auto"
                                ColumnSpacing="5"
                                VerticalOptions="Center">
                                <Label
                                    Grid.Column="0"
                                    FontAttributes="Bold"
                                    Text="John Doe " />
                                <Label
                                    Grid.Column="1"
                                    FontAttributes="Bold"
                                    Text="." 
                                    FontSize="14"
                                    Margin="0, -7, 0, 0"
                                    VerticalOptions="Center"/>
                                <Label
                                    Grid.Column="2"
                                    FontSize="12"
                                    Text="12 April 2026"
                                    VerticalOptions="Center"/>
                            </Grid>
                        </Grid>

                        <Border Grid.Row="1"
                            BackgroundColor="{StaticResource Surface}"
                                HeightRequest="250"
                                StrokeThickness="0">
                            <Image Aspect="Center"
                               HeightRequest="250"
                               Source="hallstatt.jpg" />
                        </Border>

                        <VerticalStackLayout Grid.Row="2" Spacing="10">
                            <BoxView Style="{StaticResource fadedLine}" />
                            <FlexLayout JustifyContent="SpaceAround">
                                <HorizontalStackLayout Spacing="2">
                                    <controls:PrimaryColorImage 
                                        HeightRequest="20"
                                        Source="candle.svg"
                                        VerticalOptions="Center"
                                        WidthRequest="20" />
                                    <Label
                                        FontSize="12"
                                        Text="Light"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="2">
                                    <controls:PrimaryColorImage 
                                        HeightRequest="20"
                                        Source="bubble.png"
                                        VerticalOptions="Center"
                                        WidthRequest="20" />
                                    <Label
                                        FontSize="12"
                                        Text="Comment"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="2">
                                    <controls:PrimaryColorImage 
                                        HeightRequest="20"
                                        Source="bookmark.png"
                                        VerticalOptions="Center"
                                        WidthRequest="20" />
                                    <Label
                                        FontSize="12"
                                        Text="Save"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="2">
                                    <controls:PrimaryColorImage 
                                        HeightRequest="20"
                                        Source="share.svg"
                                        VerticalOptions="Center"
                                        WidthRequest="20" />
                                    <Label
                                        FontSize="12"
                                        Text="Share"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </FlexLayout>
                        </VerticalStackLayout>

                    </Grid>
                </Border>
                <Border Padding="0, 8" BackgroundColor="{StaticResource White}" StrokeThickness="0">
                    <Grid RowDefinitions="Auto, Auto, Auto" RowSpacing="6">
                        <Grid ColumnDefinitions="40, Auto, *" ColumnSpacing="6" Padding="8, 0">
                            <Border Grid.Column="0"
                                HeightRequest="40"
                                StrokeShape="RoundRectangle 20"
                                    BackgroundColor="{StaticResource Surface}"
                                WidthRequest="40">
                                <Image 
                                    Source="user.png"
                                   Aspect="AspectFit"
                                   HeightRequest="30"
                                   WidthRequest="30"
                                   VerticalOptions="Center"
                                    HorizontalOptions="Center"/>
                            </Border>
                            <Grid
                                Grid.Column="1"
                                ColumnDefinitions="Auto, Auto, Auto"
                                ColumnSpacing="5"
                                VerticalOptions="Center">
                                <Label
                                    Grid.Column="0"
                                    FontAttributes="Bold"
                                    Text="Jim Placeholder" />
                                <Label
                                    Grid.Column="1"
                                    FontAttributes="Bold"
                                    Text="." 
                                    FontSize="14"
                                    Margin="0, -7, 0, 0"
                                    VerticalOptions="Center"/>
                                <Label
                                    Grid.Column="2"
                                    FontSize="12"
                                    Text="12 April 2026"
                                    VerticalOptions="Center"/>
                            </Grid>
                        </Grid>

                        <Label
                            Grid.Row="1"
                            FontSize="15"
                            Text="Meow, meow."
                            TextColor="{StaticResource SecondaryDarkText}" 
                            Padding="8, 0"/>

                        <VerticalStackLayout Grid.Row="3" Spacing="10">
                            <BoxView Style="{StaticResource fadedLine}" />
                            <FlexLayout JustifyContent="SpaceAround">
                                <HorizontalStackLayout Spacing="2">
                                    <controls:PrimaryColorImage 
                                        HeightRequest="20"
                                        Source="candle.svg"
                                        VerticalOptions="Center"
                                        WidthRequest="20" />
                                    <Label
                                        FontSize="12"
                                        Text="Light"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="2">
                                    <controls:PrimaryColorImage 
                                        HeightRequest="20"
                                        Source="bubble.png"
                                        VerticalOptions="Center"
                                        WidthRequest="20" />
                                    <Label
                                        FontSize="12"
                                        Text="Comment"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="2">
                                    <controls:PrimaryColorImage 
                                        HeightRequest="20"
                                        Source="bookmark.png"
                                        VerticalOptions="Center"
                                        WidthRequest="20" />
                                    <Label
                                        FontSize="12"
                                        Text="Save"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="2">
                                    <controls:PrimaryColorImage 
                                        HeightRequest="20"
                                        Source="share.svg"
                                        VerticalOptions="Center"
                                        WidthRequest="20" />
                                    <Label
                                        FontSize="12"
                                        Text="Share"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </FlexLayout>
                        </VerticalStackLayout>

                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
            
    </Grid>

</ContentPage>