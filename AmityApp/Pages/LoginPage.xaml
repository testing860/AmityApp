<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AmityApp.Controls"
             x:Class="AmityApp.Pages.LoginPage"
             Title="Login"
             Padding="20">
    <ScrollView>
        <Grid RowDefinitions="Auto, Auto, Auto"
       RowSpacing="20"
       VerticalOptions="Center">

            <Image Grid.Row="0"
            HeightRequest="158"
            Source="amity_logo.png" />

            <Label Grid.Row="1"
            FontAttributes="Bold"
            FontSize="30"
            HorizontalOptions="Center"
            Text="Login" />

            <VerticalStackLayout Grid.Row="2" Spacing="2">
                <Label Text="Username" Style="{StaticResource formLabel}"/>

                <controls:NoBorderEntry Placeholder="Enter a Username.." />

                <controls:Spacer />

                <Label Text="Password" Style="{StaticResource formLabel}"/>
                <controls:NoBorderEntry IsPassword="True" Placeholder="Enter a Password.." />

                <controls:Spacer />
                <Button Style="{StaticResource rounded}" Text="Login" Clicked="LoginBtn_Clicked"/>
                <controls:Spacer />



                <Grid ColumnDefinitions ="*, Auto, *" ColumnSpacing="5">
                    <BoxView
                 Grid.Column="0"
                 Style="{StaticResource fadedLine}" />
                    <Label 
                 Grid.Column="1"
                 HorizontalOptions ="Center" 
                 Text="New user? Join Amity now!" />
                    <BoxView
                 Grid.Column="2"
                 Style="{StaticResource fadedLine}" />
                </Grid>

                <controls:Spacer />
                <Button 
                    Clicked="RegisterBtn_Clicked"
                    Style="{StaticResource rounded}" 
                    Text="Create New Account" />
            </VerticalStackLayout>

        </Grid>
    </ScrollView>
</ContentPage>